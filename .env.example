# 傳家知保 — 環境變數說明
# 複製此檔案為 .env 並填入實際值

# Anthropic API Key
ANTHROPIC_API_KEY="sk-ant-api03-..."

# 登入帳密（網站後台）
SITE_USERNAME="admin"
SITE_PASSWORD="your-password"

# Session 簽名金鑰（隨機字串即可）
AUTH_SECRET="your-random-secret"

# 保單資料庫目錄（Python pipeline 的輸出資料夾）
# 包含 uuid_registry.json、analyzed/*.json、push_to_sheets.py
# 範例：/Users/yourname/Downloads/woody-agent/100_Todo/projects
DB_DIR="/path/to/woody-agent/100_Todo/projects"
